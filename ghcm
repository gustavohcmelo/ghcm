#!/usr/bin/env bash
# ghcm — entrypoint do GHCM HUB-AGENTS.
# Subcomandos: start, attach, switch, stop, status, list, plans, config, logs, clean, help

set -e

HUB="$HOME/agent-hub"
LOGS="$HUB/logs"
SESSION_PREFIX="agents-"

usage() {
  cat <<'EOF'
ghcm — GHCM (Gated Hub CLI Manager)

Uso:
  ghcm start [project_dir]      Inicia sessão tmux com 4 agentes (default: cwd atual)
  ghcm attach [slug]            Reconecta na sessão tmux (default: do cwd)
  ghcm switch [slug]            Alterna entre sessões (interativo se &gt;1; aceita slug)
  ghcm stop [slug|--all]        Encerra sessão (default: do cwd; --all encerra todas)
  ghcm status [slug]            Mostra planos/reviews do projeto (default: current-project)
  ghcm list                     Lista sessões tmux ativas
  ghcm plans [slug] [--pending|--all]   Lista planos (default: --all = pending + done)
  ghcm plans [slug] export <plan-id>    Gera PDF em state/<slug>/exports/ (id parcial OK)
  ghcm config [--reset]         Edita config.sh (--reset restaura do template)
  ghcm logs [name]              Lista logs / mostra um log específico
  ghcm logs --prune [N]         Apaga logs antigos, mantém os últimos N (default 20)
  ghcm clean <slug> [--yes]     Apaga state/<slug>/ inteiro (planos e reviews)
  ghcm help                     Mostra esta ajuda

Arquivos:
  ~/agent-hub/config.sh             comandos por role
  ~/agent-hub/current-project.txt   projeto ativo
  ~/agent-hub/state/<slug>/         planos e reviews por projeto
  ~/agent-hub/logs/                 logs históricos (timestamped)
EOF
}

# Lê current-project.txt e devolve slug do projeto ativo. Vazio se não existe.
current_slug() {
  local path
  path=$(cat "$HUB/current-project.txt" 2>/dev/null || echo "")
  [ -n "$path" ] && basename "$path"
}

# Resolve slug a partir do arg ou cwd ou current-project.
resolve_slug() {
  local arg=$1
  if [ -n "$arg" ]; then
    echo "$arg"
    return
  fi
  # Tenta inferir do cwd
  if [ -d "$HUB/state/$(basename "$PWD")" ]; then
    basename "$PWD"
    return
  fi
  # Fallback: current-project
  current_slug
}

# Conta arquivos .md em um diretório (sem recursão), 0 se vazio/inexistente.
count_md() {
  local dir=$1
  [ -d "$dir" ] || { echo 0; return; }
  find "$dir" -maxdepth 1 -type f -name '*.md' 2>/dev/null | wc -l
}

# Lista nomes (apenas filename) de arquivos .md em um diretório.
list_md() {
  local dir=$1
  [ -d "$dir" ] || return
  find "$dir" -maxdepth 1 -type f -name '*.md' 2>/dev/null \
    -exec basename {} \; | sort
}

# Verifica se arquivo .md tem frontmatter YAML válido (--- na linha 1).
has_frontmatter() {
  local file=$1
  [ -f "$file" ] || return 1
  head -1 "$file" 2>/dev/null | grep -q '^---$'
}

# Strip do frontmatter YAML (--- ... ---) das primeiras linhas.
# Echoa o conteúdo restante. Se não tem frontmatter, echoa o arquivo todo.
strip_frontmatter() {
  local file=$1
  awk '
    BEGIN { fm = 0 }
    NR == 1 && /^---$/ { fm = 1; next }
    fm == 1 && /^---$/ { fm = 2; next }
    fm != 1 { print }
  ' "$file"
}

# Resolve plan-id (parcial ou completo) -> caminho absoluto do .md.
# Procura em state/<slug>/plans/{pending,done}/. Echoa o caminho no stdout
# se único; em caso de zero ou múltiplos matches, escreve mensagem em stderr
# e retorna 1.
find_plan() {
  local slug=$1 query=$2
  local state="$HUB/state/$slug"
  local matches=()
  local dir f
  for dir in "$state/plans/pending" "$state/plans/done"; do
    [ -d "$dir" ] || continue
    while IFS= read -r f; do
      [ -n "$f" ] && matches+=("$f")
    done < <(find "$dir" -maxdepth 1 -type f -name "*${query}*.md" 2>/dev/null)
  done

  if [ ${#matches[@]} -eq 0 ]; then
    echo "Erro: nenhum plano casa com '$query' em $state/plans/{pending,done}/" >&2
    return 1
  fi
  if [ ${#matches[@]} -gt 1 ]; then
    echo "Erro: '$query' é ambíguo — múltiplos planos casam:" >&2
    for f in "${matches[@]}"; do
      echo "  - $(basename "$f" .md)" >&2
    done
    echo "Refine o ID." >&2
    return 1
  fi
  echo "${matches[0]}"
}

# Atualiza current-project.txt pro slug correspondente, lendo de
# state/<slug>/.project-path. Garante que os agentes daquela sessão
# leem o caminho certo do projeto.
set_current_project() {
  local slug=$1
  local pp="$HUB/state/$slug/.project-path"
  if [ -f "$pp" ]; then
    cat "$pp" > "$HUB/current-project.txt"
  fi
}

cmd="${1:-help}"
shift || true

case "$cmd" in

  start)
    exec "$HUB/start.sh" "$@"
    ;;

  attach)
    slug=$(resolve_slug "${1:-}")
    if [ -z "$slug" ]; then
      echo "Erro: nenhum slug informado e não foi possível inferir do cwd." >&2
      echo "Uso: ghcm attach <slug>     (ou rode dentro do diretório do projeto)" >&2
      exit 1
    fi
    session="${SESSION_PREFIX}${slug}"
    if ! tmux has-session -t "$session" 2>/dev/null; then
      echo "Sessão '$session' não está rodando."
      echo "Inicie com: ghcm start"
      exit 1
    fi
    set_current_project "$slug"
    exec tmux attach -t "$session"
    ;;

  switch)
    sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${SESSION_PREFIX}" || true)
    if [ -z "$sessions" ]; then
      echo "Nenhuma sessão '${SESSION_PREFIX}*' rodando. Inicie com: ghcm start"
      exit 1
    fi

    target_slug="${1:-}"
    if [ -z "$target_slug" ]; then
      mapfile -t sess_arr <<< "$sessions"
      count=${#sess_arr[@]}
      if [ "$count" -eq 1 ]; then
        target_slug="${sess_arr[0]#$SESSION_PREFIX}"
      else
        cur=$(current_slug)
        echo "Sessões ativas:"
        for i in "${!sess_arr[@]}"; do
          local_slug="${sess_arr[$i]#$SESSION_PREFIX}"
          marker=" "
          [ "$local_slug" = "$cur" ] && marker="*"
          printf "  %s %d) %s\n" "$marker" "$((i+1))" "${sess_arr[$i]}"
        done
        read -r -p "Escolha [1-$count]: " choice
        if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "$count" ]; then
          echo "Escolha inválida." >&2
          exit 1
        fi
        target_slug="${sess_arr[$((choice-1))]#$SESSION_PREFIX}"
      fi
    fi

    session="${SESSION_PREFIX}${target_slug}"
    if ! tmux has-session -t "$session" 2>/dev/null; then
      echo "Sessão '$session' não encontrada." >&2
      exit 1
    fi
    set_current_project "$target_slug"

    # Se já estamos dentro de um tmux, troca a sessão atual em vez de attach
    # (que falha quando já há sessão attached).
    if [ -n "${TMUX:-}" ]; then
      exec tmux switch-client -t "$session"
    fi
    exec tmux attach -t "$session"
    ;;

  stop)
    target=${1:-}
    if [ "$target" = "--all" ]; then
      sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${SESSION_PREFIX}" || true)
      if [ -z "$sessions" ]; then
        echo "Nenhuma sessão '${SESSION_PREFIX}*' rodando."
        exit 0
      fi
      while IFS= read -r s; do
        tmux kill-session -t "$s" && echo "Encerrada: $s"
      done <<< "$sessions"
      exit 0
    fi

    slug=$(resolve_slug "$target")
    if [ -z "$slug" ]; then
      echo "Erro: nenhum slug informado e não foi possível inferir. Uso: ghcm stop <slug>" >&2
      exit 1
    fi
    session="${SESSION_PREFIX}${slug}"
    if tmux has-session -t "$session" 2>/dev/null; then
      tmux kill-session -t "$session"
      echo "Sessão '$session' encerrada."
    else
      echo "Nenhuma sessão '$session' rodando."
    fi
    ;;

  status)
    slug=$(resolve_slug "${1:-}")
    if [ -z "$slug" ]; then
      echo "Erro: sem projeto ativo. Rode 'ghcm start' primeiro ou passe um slug." >&2
      exit 1
    fi

    state="$HUB/state/$slug"
    if [ ! -d "$state" ]; then
      echo "Projeto '$slug' não tem state em $state." >&2
      exit 1
    fi

    # Resolve o path absoluto pra esse slug específico:
    # 1º preferência: state/<slug>/.project-path (escrito pelo start.sh)
    # 2º fallback: current-project.txt (só faz sentido se for o projeto atual)
    if [ -f "$state/.project-path" ]; then
      project_path=$(cat "$state/.project-path")
    elif [ "$slug" = "$(current_slug)" ]; then
      project_path=$(cat "$HUB/current-project.txt" 2>/dev/null || echo "(desconhecido)")
    else
      project_path="(desconhecido — abra o projeto com 'ghcm start' pra registrar)"
    fi
    session="${SESSION_PREFIX}${slug}"
    if tmux has-session -t "$session" 2>/dev/null; then
      session_status="ativa"
    else
      session_status="inativa"
    fi

    echo "Projeto:     $project_path"
    echo "Slug:        $slug"
    echo "Sessão tmux: $session ($session_status)"
    echo

    plans_pending=$(count_md "$state/plans/pending")
    plans_done=$(count_md "$state/plans/done")
    rev_pending=$(count_md "$state/reviews/pending")
    rev_approved=$(count_md "$state/reviews/done/approved")
    rev_rejected=$(count_md "$state/reviews/done/rejected")
    rev_shipped=$(count_md "$state/reviews/done/shipped")

    echo "Plans:"
    echo "  pending: $plans_pending"
    list_md "$state/plans/pending" | sed 's/^/    /'
    echo "  done:    $plans_done"
    echo

    echo "Reviews:"
    echo "  pending:  $rev_pending"
    list_md "$state/reviews/pending" | sed 's/^/    /'
    echo "  approved: $rev_approved"
    list_md "$state/reviews/done/approved" | sed 's/^/    /'
    echo "  rejected: $rev_rejected"
    list_md "$state/reviews/done/rejected" | sed 's/^/    /'
    echo "  shipped:  $rev_shipped"
    echo

    # Validação leve: warning pra arquivos sem frontmatter.
    missing_fm=()
    while IFS= read -r f; do
      [ -n "$f" ] || continue
      has_frontmatter "$f" || missing_fm+=("$f")
    done < <(find "$state/plans" "$state/reviews" -type f -name '*.md' 2>/dev/null)

    if [ ${#missing_fm[@]} -gt 0 ]; then
      echo "Aviso: ${#missing_fm[@]} arquivo(s) sem frontmatter YAML (legados):"
      for f in "${missing_fm[@]}"; do
        echo "  - ${f#$HUB/}"
      done
    fi
    ;;

  list)
    sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${SESSION_PREFIX}" || true)
    if [ -z "$sessions" ]; then
      echo "Nenhuma sessão ativa. Inicie com: ghcm start"
      exit 0
    fi
    echo "Sessões ativas:"
    while IFS= read -r s; do
      echo "  ${s#$SESSION_PREFIX}"
    done <<< "$sessions"
    ;;

  plans)
    # Args possíveis (em qualquer ordem):
    #   [slug]                     — slug de um projeto conhecido (override do current)
    #   --pending | --all          — filtro
    #   export <plan-id>           — subcomando de exportação
    action="list"
    filter="--all"
    plan_id=""
    slug_arg=""
    while [ $# -gt 0 ]; do
      case "$1" in
        export)
          action="export"
          plan_id=${2:-}
          shift 2 || shift
          ;;
        --pending|--all)
          filter=$1
          shift
          ;;
        -*)
          echo "Flag desconhecida: $1" >&2
          exit 1
          ;;
        *)
          if [ -z "$slug_arg" ]; then
            slug_arg=$1
            shift
          else
            echo "Argumento extra: $1" >&2
            exit 1
          fi
          ;;
      esac
    done

    slug=$(resolve_slug "$slug_arg")
    if [ -z "$slug" ]; then
      echo "Erro: sem projeto ativo. Rode 'ghcm start' ou passe um slug." >&2
      exit 1
    fi
    state="$HUB/state/$slug"
    if [ ! -d "$state" ]; then
      echo "Erro: projeto '$slug' sem state em $state." >&2
      exit 1
    fi

    if [ "$action" = "export" ]; then
      if [ -z "$plan_id" ]; then
        echo "Uso: ghcm plans export <plan-id>" >&2
        exit 1
      fi
      if ! command -v pandoc >/dev/null 2>&1; then
        echo "Erro: pandoc não instalado. Rode: sudo apt install pandoc" >&2
        exit 1
      fi

      plan_file=$(find_plan "$slug" "$plan_id") || exit 1

      exports="$state/exports"
      mkdir -p "$exports"

      base=$(basename "$plan_file" .md)
      out="$exports/$base.pdf"

      # NÃO stripa frontmatter — pandoc lê os campos como metadata e o template
      # injeta na capa (project_slug, status, type, created_at, version, id).
      # Extrai o primeiro h1 do markdown pra usar como `title` (capa fica humana
      # em vez de mostrar só o id técnico).
      plan_title=$(awk '/^# / { sub(/^# +/, ""); print; exit }' "$plan_file")
      css="$HUB/templates/plan-pdf.css"
      tpl="$HUB/templates/plan-pdf-template.html"
      pandoc_args=(-o "$out" --pdf-engine=weasyprint --standalone)
      [ -f "$tpl" ] && pandoc_args+=(--template="$tpl")
      [ -f "$css" ] && pandoc_args+=(--css="$css")
      [ -n "$plan_title" ] && pandoc_args+=(--metadata "title=$plan_title")

      if ! pandoc "$plan_file" "${pandoc_args[@]}"; then
        echo "Erro: pandoc falhou ao gerar PDF." >&2
        exit 1
      fi
      echo "$out"
      exit 0
    fi

    # action=list
    echo "Slug: $slug"
    echo

    pending_count=$(count_md "$state/plans/pending")
    echo "Pending ($pending_count):"
    list_md "$state/plans/pending" | sed 's/\.md$//' | sed 's/^/  /'

    if [ "$filter" = "--all" ]; then
      echo
      done_count=$(count_md "$state/plans/done")
      echo "Done ($done_count):"
      list_md "$state/plans/done" | sed 's/\.md$//' | sed 's/^/  /'
    fi
    ;;

  config)
    if [ "${1:-}" = "--reset" ]; then
      if [ ! -f "$HUB/config.example.sh" ]; then
        echo "Erro: $HUB/config.example.sh não existe — não tem como resetar." >&2
        exit 1
      fi
      if [ -f "$HUB/config.sh" ]; then
        read -r -p "Sobrescrever $HUB/config.sh com o template? [y/N] " ans
        [[ "$ans" =~ ^[yY] ]] || { echo "Cancelado."; exit 0; }
      fi
      cp "$HUB/config.example.sh" "$HUB/config.sh"
      echo "OK: $HUB/config.sh restaurado do template."
      exit 0
    fi

    if [ ! -f "$HUB/config.sh" ] && [ -f "$HUB/config.example.sh" ]; then
      cp "$HUB/config.example.sh" "$HUB/config.sh"
      echo "Criado $HUB/config.sh a partir do template."
    fi
    editor="${EDITOR:-}"
    if [ -z "$editor" ]; then
      for cand in nano vim vi; do
        if command -v "$cand" >/dev/null 2>&1; then
          editor="$cand"
          break
        fi
      done
    fi
    if [ -z "$editor" ]; then
      echo "Erro: nenhum editor encontrado. Defina \$EDITOR." >&2
      exit 1
    fi
    exec "$editor" "$HUB/config.sh"
    ;;

  logs)
    target=${1:-}
    mkdir -p "$LOGS"

    if [ "$target" = "--prune" ]; then
      keep=${2:-20}
      if ! [[ "$keep" =~ ^[0-9]+$ ]]; then
        echo "Erro: --prune espera um número (ex: ghcm logs --prune 20)." >&2
        exit 1
      fi
      total=$(find "$LOGS" -maxdepth 1 -type f 2>/dev/null | wc -l)
      if [ "$total" -le "$keep" ]; then
        echo "$total logs em $LOGS/ — nada a apagar (mantendo últimos $keep)."
        exit 0
      fi
      to_delete=$((total - keep))
      ls -1t "$LOGS" 2>/dev/null | tail -n "+$((keep + 1))" | while IFS= read -r f; do
        rm -f "$LOGS/$f"
      done
      echo "Apagados $to_delete log(s). Mantidos $keep mais recentes."
      exit 0
    fi

    if [ -n "$target" ]; then
      log_file="$LOGS/$target"
      if [ ! -f "$log_file" ]; then
        echo "Erro: log '$target' não encontrado em $LOGS." >&2
        exit 1
      fi
      exec less "$log_file"
    fi

    # Sem arg: lista logs em ordem cronológica decrescente.
    echo "Logs em $LOGS/:"
    if [ -z "$(ls -A "$LOGS" 2>/dev/null)" ]; then
      echo "  (nenhum log)"
    else
      ls -1t "$LOGS" 2>/dev/null | sed 's/^/  /'
      echo
      echo "Pra ver um log:    ghcm logs <nome>"
      echo "Pra apagar antigos: ghcm logs --prune [N]   (default mantém 20)"
    fi
    ;;

  clean)
    target_slug=${1:-}
    yes_flag=${2:-}
    if [ -z "$target_slug" ]; then
      echo "Erro: informe o slug. Uso: ghcm clean <slug> [--yes]" >&2
      exit 1
    fi
    state="$HUB/state/$target_slug"
    if [ ! -d "$state" ]; then
      echo "Erro: '$state' não existe." >&2
      exit 1
    fi
    session="${SESSION_PREFIX}${target_slug}"
    if tmux has-session -t "$session" 2>/dev/null; then
      echo "Erro: sessão '$session' está rodando. Encerre com 'ghcm stop $target_slug' antes." >&2
      exit 1
    fi

    plans_pending=$(count_md "$state/plans/pending")
    plans_done=$(count_md "$state/plans/done")
    rev_pending=$(count_md "$state/reviews/pending")
    rev_approved=$(count_md "$state/reviews/done/approved")
    rev_rejected=$(count_md "$state/reviews/done/rejected")
    rev_shipped=$(count_md "$state/reviews/done/shipped")

    echo "Vai apagar permanentemente:"
    echo "  $state"
    echo "    plans:    $plans_pending pending, $plans_done done"
    echo "    reviews:  $rev_pending pending, $rev_approved approved, $rev_rejected rejected, $rev_shipped shipped"
    echo "Isso NÃO afeta o projeto em si (só o estado do orquestrador)."
    echo

    if [ "$yes_flag" != "--yes" ]; then
      read -r -p "Confirma? [y/N] " ans
      [[ "$ans" =~ ^[yY] ]] || { echo "Cancelado."; exit 0; }
    fi

    rm -rf "$state"
    echo "OK: $state apagado."

    # Se era o current-project, limpa current-project.txt também
    if [ "$(current_slug)" = "$target_slug" ]; then
      rm -f "$HUB/current-project.txt"
      echo "OK: current-project.txt limpo (era esse projeto)."
    fi
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    echo "Subcomando desconhecido: $cmd" >&2
    echo
    usage
    exit 1
    ;;
esac
